name: Random Forest system project

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      df_path: {type: path, default: "./data.csv"}
      
      target_col: {type: string, default: "target"}
      
      # hint: masukkan nilai json array/python list
      n_estimators: {type: string, default: "[50, 100, 150]"}
      
      # hint: masukkan nilai json array/python list
      max_depth: {type: string, default: "[None, 10, 20]"}

      # hint: masukkan nilai json array/python list
      random_seed: {type: string, default: "[42]"}
      
    command: "python modelling.py --df_path {df_path} --target_col {target_col} --n_estimators '{n_estimators}' --max_depth '{max_depth}' --random_seed '{random_seed}'"
